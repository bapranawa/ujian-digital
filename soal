    let quizData = [], answers = [], doubtStatus = [], current = 0, timer, totalSec = 75 * 60;

    databaseSoal.trim().split(/\n\s*\n/).forEach(block => {
        let [teksSoal, teksOpsi] = block.split('###');
        if (teksSoal) {
            let q = teksSoal.trim().replace(/\n/g, '<br>');
            let opts = [], keys = [];
            if (teksOpsi) {
                let lines = teksOpsi.trim().split('\n').map(l => l.trim()).filter(l => l !== "");
                lines.forEach(line => {
                    if (q.includes("[TABEL]")) {
                        let parts = line.split("|").map(p => p.trim());
                        let subQ = parts[0];
                        let subOpts = parts.slice(1).map(o => o.replace('*','').trim());
                        let subKey = parts.slice(1).find(o => o.includes('*'))?.replace('*','').trim();
                        opts.push({subQ, subOpts}); keys.push(subKey);
                    } else {
                        let txt = line.replace('*','').trim();
                        if (line.includes('*')) keys.push(txt);
                        opts.push(txt);
                    }
                });
            }
            quizData.push({q, opts, keys});
        }
    });

    function toggleSidebar() {
        const side = document.getElementById('sidebar');
        side.classList.toggle('open');
        document.getElementById('toggleNavBtn').innerHTML = side.classList.contains('open') ? "✕ Tutup" : "☰ Nomor";
    }

    function showModal(title, msg, onOk = null, showCancel = false) {
        document.getElementById('modalTitle').innerText = title;
        document.getElementById('modalMsg').innerText = msg;
        const footer = document.getElementById('modalFooter');
        footer.innerHTML = "";
        if(showCancel) {
            let btnBatal = document.createElement("button");
            btnBatal.className = "btn"; btnBatal.style.background = "#ccc"; btnBatal.innerText = "Batal";
            btnBatal.onclick = closeModal; footer.appendChild(btnBatal);
        }
        let btnOk = document.createElement("button");
        btnOk.className = "btn btn-blue"; btnOk.innerText = "Oke";
        btnOk.onclick = () => { closeModal(); if(onOk) onOk(); };
        footer.appendChild(btnOk);
        document.getElementById('customModal').style.display = 'flex';
    }

    function closeModal() { document.getElementById('customModal').style.display = 'none'; }

    function mulai() {
        const n = document.getElementById('stuName').value, a = document.getElementById('stuNo').value;
        if(!n || !a) return showModal("Peringatan", "Lengkapi identitas!");
        
        localStorage.setItem('wonosari_sekolah', document.getElementById('stuSekolah').value);
        localStorage.setItem('wonosari_name', n);
        localStorage.setItem('wonosari_no', a);
        localStorage.setItem('wonosari_mapel', document.getElementById('stuMapel').value);
        
        answers = JSON.parse(localStorage.getItem('wonosari_ans')) || new Array(quizData.length).fill(null);
        doubtStatus = JSON.parse(localStorage.getItem('wonosari_doubt')) || new Array(quizData.length).fill(false);
        
        const lastNum = parseInt(localStorage.getItem('wonosari_last_num'));
        if(!isNaN(lastNum) && lastNum >= 0 && lastNum < quizData.length) current = lastNum;

        document.getElementById('login-sec').style.display = 'none';
        document.getElementById('exam-sec').style.display = 'grid';
        tampil();
        timer = setInterval(updateTimer, 1000);
    }

    function updateTimer() {
        totalSec--;
        if(totalSec <= 0) { clearInterval(timer); selesai(); return; }
        let m = Math.floor(totalSec/60), s = totalSec % 60;
        document.getElementById('timer').innerText = `${m}:${s<10?'0'+s:s}`;
    }

    function tampil(shouldScroll = false) {
        const sek = localStorage.getItem('wonosari_sekolah'), nam = localStorage.getItem('wonosari_name'), 
              abs = localStorage.getItem('wonosari_no'), map = localStorage.getItem('wonosari_mapel');
        document.getElementById('identitas-running').innerText = `${sek} | ${nam} (${abs}) | ${map}`;

        localStorage.setItem('wonosari_last_num', current);
        let d = quizData[current], isMCMA = d.q.includes("[MCMA]"), isTABEL = d.q.includes("[TABEL]");
        document.getElementById('q-num').innerText = "Soal No. " + (current + 1);
        document.getElementById('q-text').innerHTML = d.q.replace("[TABEL]","").replace("[MCMA]","").replace(/\[IMG:\s*(.*?)\]/g, '<img src="$1" class="q-img">');
        
        let html = "";
        if (isTABEL) {
            html += `<div class="table-responsive"><table class="soal-tabel"><tr><th>Pernyataan</th><th>${d.opts[0].subOpts[0]}</th><th>${d.opts[0].subOpts[1]}</th></tr>`;
            d.opts.forEach((o, row) => {
                html += `<tr><td>${o.subQ}</td>`;
                o.subOpts.forEach(opt => {
                    let sel = (Array.isArray(answers[current]) && answers[current][row] === opt);
                    html += `<td class="cell-opt ${sel?'selected':''}" onclick="pilihTabel(${row}, '${opt}')">${opt}</td>`;
                });
                html += `</tr>`;
            });
            html += `</table></div>`;
        } else {
            d.opts.forEach(o => {
                let sel = isMCMA ? (Array.isArray(answers[current]) && answers[current].includes(o)) : (answers[current] === o);
                html += `<div class="option ${sel?'selected':''}" onclick="pilih('${o}', ${isMCMA})">
                    <div class="${isMCMA?'opt-box':'opt-circle'}"></div><span>${o}</span></div>`;
            });
        }
        document.getElementById('opt-area').innerHTML = html;
        renderNav();
        
        // Hanya scroll ke atas jika tombol navigasi "Lanjut/Kembali" atau nomor diklik
        if(shouldScroll) window.scrollTo({top: 0, behavior: 'smooth'});

        if(document.getElementById('sidebar').classList.contains('open')) toggleSidebar();
    }

    function pilih(v, isMCMA) {
        if(isMCMA) {
            if(!Array.isArray(answers[current])) answers[current] = [];
            let i = answers[current].indexOf(v);
            if(i > -1) answers[current].splice(i, 1); else answers[current].push(v);
            if(answers[current].length === 0) answers[current] = null;
        } else answers[current] = v;
        localStorage.setItem('wonosari_ans', JSON.stringify(answers));
        tampil(false); // Parameter false agar tidak scroll ke atas saat pilih jawaban
    }

    function pilihTabel(row, val) {
        if(!Array.isArray(answers[current])) answers[current] = new Array(quizData[current].opts.length).fill(null);
        answers[current][row] = val;
        localStorage.setItem('wonosari_ans', JSON.stringify(answers));
        tampil(false); // Parameter false agar tidak scroll ke atas saat pilih jawaban
    }

    function toggleDoubt() { 
        doubtStatus[current] = !doubtStatus[current]; 
        localStorage.setItem('wonosari_doubt', JSON.stringify(doubtStatus));
        renderNav(); 
    }

    function renderNav() {
        let html = "";
        for(let i=0; i<quizData.length; i++) {
            let q = quizData[i], ans = answers[i], lengkap = false;
            if(q.q.includes("[MCMA]")) lengkap = Array.isArray(ans) && ans.length > 0;
            else if(q.q.includes("[TABEL]")) lengkap = Array.isArray(ans) && ans.length === q.opts.length && ans.every(x => x !== null);
            else lengkap = !!ans;
            let cls = "num-btn" + (i===current?" active":"") + (doubtStatus[i]?" doubt":(lengkap?" filled":""));
            html += `<div class="${cls}" onclick="current=${i};tampil(true)">${i+1}</div>`;
        }
        document.getElementById('num-grid').innerHTML = html;
    }

    function resetSemuaDraf() {
        showModal("Hapus Draf", "Yakin hapus semua jawaban?", () => { localStorage.clear(); location.reload(); }, true);
    }

    function nav(v, scroll) { 
        let t = current + v; 
        if(t>=0 && t<quizData.length) { current = t; tampil(scroll); }
    }

    function cekSebelumSelesai() {
        let kosong = [];
        quizData.forEach((q, i) => {
            let ans = answers[i], lengkap = false;
            if(q.q.includes("[MCMA]")) lengkap = Array.isArray(ans) && ans.length > 0;
            else if(q.q.includes("[TABEL]")) lengkap = Array.isArray(ans) && ans.length === q.opts.length && ans.every(x => x !== null);
            else lengkap = !!ans;
            if (!lengkap) kosong.push(i + 1);
        });
        if(kosong.length > 0) showModal("Belum Lengkap", "Nomor belum terisi: " + kosong.join(", "));
        else showModal("Konfirmasi", "Yakin ingin kirim jawaban?", () => selesai(), true);
    }

    function selesai() {
        clearInterval(timer);
        document.getElementById('toggleNavBtn').style.display = 'none';
        const sek = localStorage.getItem('wonosari_sekolah'), nam = localStorage.getItem('wonosari_name'), 
              abs = localStorage.getItem('wonosari_no'), map = localStorage.getItem('wonosari_mapel');
        document.getElementById('exam-sec').style.display = 'none';
        document.getElementById('result-sec').style.display = 'block';
        document.getElementById('info-pribadi').innerText = `${sek}\n${nam} (${abs})\n${map}`;
        
        let benar = 0, rincian = [];
        quizData.forEach((q, i) => {
            let isCorrect = false;
            if(q.q.includes("[TABEL]")) isCorrect = JSON.stringify(answers[i]) === JSON.stringify(q.keys);
            else if(q.q.includes("[MCMA]")) isCorrect = (answers[i]||[]).sort().join("|") === q.keys.sort().join("|");
            else isCorrect = answers[i] === q.keys[0];
            if(isCorrect) benar++;
            rincian.push(`No${i+1}:${Array.isArray(answers[i])?answers[i].join("/"):answers[i]||'-'}`);
        });
        
        let skor = Math.round((benar/quizData.length)*100);
        document.getElementById('skor-akhir').innerText = skor;
        const formData = new URLSearchParams();
        formData.append('sekolah', sek); formData.append('nama', nam);
        formData.append('absen', abs); formData.append('mapel', map);
        formData.append('nilai', skor); formData.append('analisis', rincian.join(" | "));
        
        fetch(scriptURL, { method: 'POST', body: formData, mode: 'no-cors' })
        .then(() => {
            document.getElementById('stat-kirim').innerHTML = "✅ BERHASIL TERKIRIM";
            document.getElementById('stat-kirim').style.background = "#d4edda";
            localStorage.clear();
        }).catch(() => {
            document.getElementById('stat-kirim').innerHTML = "❌ GAGAL MENGIRIM";
            document.getElementById('stat-kirim').style.background = "#f8d7da";
        });
    }

    window.onload = function() {
        if(localStorage.getItem('wonosari_name')) {
            document.getElementById('stuSekolah').value = localStorage.getItem('wonosari_sekolah');
            document.getElementById('stuName').value = localStorage.getItem('wonosari_name');
            document.getElementById('stuNo').value = localStorage.getItem('wonosari_no');
            document.getElementById('stuMapel').value = localStorage.getItem('wonosari_mapel');
            mulai();
        }
    };
</script>
</body>
</html>
