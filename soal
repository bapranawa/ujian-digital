<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ujian Digital SDN Karangrejek I</title>
    <style>
        :root { --primary: #1a73e8; --secondary: #fbbc04; --danger: #d93025; --bg: #f1f3f4; }
        body { font-family: 'Segoe UI', sans-serif; background: var(--bg); margin: 0; padding: 0; display: flex; justify-content: center; }
        .container { width: 100%; max-width: 950px; background: white; padding: 25px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); margin-top: 15px; margin-bottom: 15px; }
        
        .header-info { text-align: center; border-bottom: 2px solid #eee; margin-bottom: 20px; padding-bottom: 10px; }
        #q-text { font-size: 18px; margin-bottom: 20px; white-space: pre-line; }
        
        .exam-layout { display: none; grid-template-columns: 1fr 280px; gap: 20px; align-items: start; }
        
        /* AREA STICKY ATAS */
        .sticky-container {
            position: sticky;
            top: 0;
            background: white;
            z-index: 999;
            padding: 10px 0;
            border-bottom: 2px solid var(--primary);
            margin-bottom: 20px;
        }

        .question-area { background: #fff; border: 1px solid #ddd; padding: 20px; border-radius: 8px; min-height: 450px; position: relative; }
        
        .nav-panel { background: #f8f9fa; border: 1px solid #ddd; padding: 15px; border-radius: 8px; position: sticky; top: 20px; max-height: 85vh; overflow-y: auto; }
        .num-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px; margin-top: 10px; }
        .num-btn { padding: 10px; border: 1px solid #ccc; background: #fff; cursor: pointer; border-radius: 4px; text-align: center; font-weight: bold; font-size: 14px; }
        .num-btn.active { background: var(--primary); color: white; border-color: var(--primary); }
        .num-btn.filled { background: #e8f0fe; color: var(--primary); border-color: var(--primary); }
        .num-btn.doubt { background: var(--secondary) !important; color: white !important; }

        #toggleNavBtn { 
            display: none; 
            position: fixed; 
            top: 10px; 
            right: 10px; 
            padding: 8px 15px; 
            border-radius: 5px; 
            background: var(--primary); 
            color: white; 
            border: none; 
            font-size: 12px; 
            font-weight: bold; 
            z-index: 2100; 
            cursor: pointer; 
        }

        .table-responsive { width: 100%; overflow-x: auto; margin-top: 10px; border: 1px solid #ddd; border-radius: 8px; }
        .soal-tabel { width: 100%; border-collapse: collapse; min-width: 500px; }
        .soal-tabel th, .soal-tabel td { border: 1px solid #ccc; padding: 12px; text-align: center; }
        .cell-opt { cursor: pointer; font-weight: bold; }
        .cell-opt.selected { background: var(--primary); color: white; }

        .option { display: flex; align-items: center; border: 2px solid #eee; margin-bottom: 12px; padding: 15px; cursor: pointer; border-radius: 8px; }
        .option.selected { border-color: var(--primary); background: #e8f0fe; }
        .opt-box, .opt-circle { width: 18px; height: 18px; border: 2px solid var(--primary); margin-right: 12px; flex-shrink: 0; }
        .opt-circle { border-radius: 50%; }
        .selected .opt-box { background: var(--primary); color: white; text-align: center; line-height: 18px; }
        .selected .opt-box:after { content: '✔'; font-size: 12px; }
        .selected .opt-circle { background: var(--primary); box-shadow: inset 0 0 0 3px white; }

        .q-img { max-width: 100%; height: auto; border-radius: 8px; margin: 15px 0; display: block; }
        .btn { padding: 12px 20px; border: none; border-radius: 6px; cursor: pointer; font-weight: bold; color: white; }
        .btn-blue { background: var(--primary); }
        .btn-yellow { background: var(--secondary); }
        .btn-red { background: var(--danger); width: 100%; margin-top: 20px; }
        .btn-reset { background: #f0f0f0; color: #d93025; width: 100%; margin-top: 15px; font-size: 11px; border: 1px solid #ddd; }

        .modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 3000; justify-content: center; align-items: center; }
        .modal-box { background: white; padding: 25px; border-radius: 12px; width: 90%; max-width: 400px; text-align: center; }
        input, select { width: 100%; padding: 12px; margin: 8px 0 15px 0; border: 1px solid #ccc; border-radius: 6px; box-sizing: border-box; }

        @media screen and (max-width: 768px) {
            .exam-layout { grid-template-columns: 1fr; }
            .nav-panel { 
                position: fixed; top: 0; right: -320px; width: 280px; height: 100vh; 
                z-index: 2000; background: white; padding: 60px 20px 20px 20px; 
                box-shadow: -5px 0 15px rgba(0,0,0,0.2); transition: 0.3s;
            }
            .nav-panel.open { right: 0; }
            #toggleNavBtn { display: block; }
            .container { padding: 10px; margin-top: 0; border-radius: 0; }
            .sticky-container { top: 0; padding-top: 45px; }
        }
    </style>
</head>
<body>

<button id="toggleNavBtn" onclick="toggleSidebar()">☰ Nomor</button>

<div id="customModal" class="modal-overlay">
    <div class="modal-box">
        <h3 id="modalTitle">Pemberitahuan</h3>
        <p id="modalMsg" style="white-space: pre-line;"></p>
        <div id="modalFooter" style="display:flex; justify-content: center; gap: 10px; margin-top: 20px;">
            <button class="btn btn-blue" onclick="closeModal()">Oke</button>
        </div>
    </div>
</div>

<div class="container">
    <div id="login-sec">
        <div class="header-info"><h2>UJIAN DIGITAL</h2><h3>INPUT IDENTITAS</h3></div>
        <label>Pilih Sekolah:</label>
        <select id="stuSekolah">
            <option value="SDN KARANGREJEK I">SDN KARANGREJEK I</option>
            <option value="SD LAIN">SD LAIN</option>
        </select>
        <label>Nama Lengkap:</label><input type="text" id="stuName">
        <label>Nomor Absen:</label><input type="number" id="stuNo">
        <label>Mata Pelajaran:</label>
        <select id="stuMapel">
            <option value="BAHASA INDONESIA">BAHASA INDONESIA</option>
            <option value="IPAS">IPAS</option>
            <option value="MATEMATIKA">MATEMATIKA</option>
        </select>
        <button class="btn btn-blue" style="width:100%" onclick="mulai()">MULAI UJIAN</button>
    </div>

    <div id="exam-sec" class="exam-layout">
        <div class="question-area">
            <div class="sticky-container">
                <div id="identitas-running" style="font-size: 11px; color: #444; margin-bottom: 5px; font-weight: bold; text-transform: uppercase;"></div>
                <div style="display:flex; justify-content:space-between; align-items: center;">
                    <b id="q-num" style="color:var(--primary); font-size: 16px;">Soal No. 1</b>
                    <b id="timer" style="color:var(--danger); font-size: 16px; border: 1px solid var(--danger); padding: 2px 8px; border-radius: 4px;">75:00</b>
                </div>
            </div>

            <div id="q-text"></div>
            <div id="opt-area"></div>
            
            <div style="display:flex; justify-content:space-between; margin-top:30px; gap: 8px;">
                <button class="btn btn-blue" onclick="nav(-1, true)" style="flex:1">Kembali</button>
                <button class="btn btn-yellow" onclick="toggleDoubt()" style="flex:1">Ragu</button>
                <button class="btn btn-blue" onclick="nav(1, true)" style="flex:1">Lanjut</button>
            </div>
        </div>
        
        <div class="nav-panel" id="sidebar">
            <h4 style="margin:0">Daftar Soal</h4>
            <div id="num-grid" class="num-grid"></div>
            <button class="btn btn-red" onclick="cekSebelumSelesai()">SELESAI & KIRIM</button>
            <button class="btn btn-reset" onclick="resetSemuaDraf()">HAPUS SEMUA JAWABAN</button>
        </div>
    </div>

    <div id="result-sec" style="display:none; text-align:center">
        <h2>HASIL UJIAN</h2>
        <h1 id="skor-akhir" style="font-size:80px; color:var(--primary)">0</h1>
        <div id="info-pribadi" style="margin-bottom: 20px; font-weight: bold; white-space: pre-line;"></div>
        <div id="stat-kirim" style="padding:15px; border-radius:8px; background: #eee;">Sedang mengirim...</div>
    </div>
</div>

<script>
